# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Wallet Private Key (for signing transactions and auto-generating auth tokens)
# The wallet address is automatically derived from this private key
# DO NOT hardcode this - use Replit Secrets or environment variables!
WALLET_PRIVATE_KEY=0xyour_private_key_here

# Allowed Telegram User IDs (comma separated, leave empty to allow all)
# WAJIB diisi agar notifikasi auto scheduler bisa terkirim!
# Cari Telegram User ID kamu di @userinfobot
ALLOWED_USER_IDS=

# ─── Auto Scheduler ──────────────────────────────────────────────────────────
# Aktifkan/matikan auto scheduler (default: true)
AUTO_SCHEDULER=true

# Jam otomatis jalan (format 24 jam, default: 00 = tengah malam)
AUTO_HOUR=0

# Menit otomatis jalan (default: 05)
AUTO_MINUTE=5

# Timezone (default: Asia/Jakarta / WIB)
AUTO_TIMEZONE=Asia/Jakarta

# Auto claim faucet setiap hari (default: true)
AUTO_FAUCET=true

# Auto complete daily quests setiap hari (default: true)
AUTO_DAILY_QUESTS=true

# ─── Auto Swap (EcoDex) ───────────────────────────────────────────────────────
# Aktifkan auto swap harian di EcoDex (default: false, set true untuk aktifkan)
AUTO_SWAP=false

# Jumlah X1T yang di-swap per hari (default: 0.01 X1T)
# Bot akan swap: X1T → WX1T → USDT → WX1T → X1T (round trip)
SWAP_AMOUNT=0.01
